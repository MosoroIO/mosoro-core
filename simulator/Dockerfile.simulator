FROM python:3.11-slim

WORKDIR /app

# Install only the dependencies needed by the simulator
RUN pip install --no-cache-dir paho-mqtt>=2.1.0 PyYAML>=6.0.2

# Copy simulator source
COPY simulator/ simulator/

# Non-root user for security
RUN useradd -m mosoro && chown -R mosoro:mosoro /app
USER mosoro

CMD ["python", "-m", "simulator.virtual_fleet"]
