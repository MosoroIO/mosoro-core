# Mosoro Robot Configuration
# Auto-generated by: make setup
# Add robots manually or re-run: make add-robot
#
# Each robot needs:
#   - id: unique identifier
#   - vendor: adapter name (must be installed)
#   - connection details specific to the vendor

robots:
  - id: locus-001
    vendor: locus
    api_base_url: "http://192.168.1.100:8080/api"
    api_key: "your-api-key"

  - id: mir-001
    vendor: mir
    api_base_url: "http://192.168.1.101:8080"
    username: admin
    password: "your-password"

  - id: stretch-001
    vendor: stretch
    rosbridge_host: "192.168.1.102"
    rosbridge_port: 9090
    map_id: "warehouse_map_01"
