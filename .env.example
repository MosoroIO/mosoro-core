# =============================================================================
# Mosoro Core — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running.
# DO NOT commit the .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose -f docker/docker-compose.prod.yml --env-file .env up
# =============================================================================

# --- MQTT Broker Connection ---
MQTT_BROKER_HOST=mosquitto           # Hostname of the Mosquitto MQTT broker
MQTT_BROKER_PORT=8883                # Port (8883 = TLS, 1883 = plain)
MQTT_USE_TLS=true                    # Enable TLS for MQTT connections (true/false)
# MQTT_USERNAME=                     # Optional: MQTT username (if not using mTLS)
# MQTT_PASSWORD=                     # Optional: MQTT password (if not using mTLS)

# --- TLS / mTLS Certificates ---
# Paths to TLS certificates for secure MQTT communication.
# In Docker, these are typically mounted via secrets or volumes.
MQTT_CA_CERT=/run/secrets/mqtt_ca_cert       # CA certificate for server verification
# MQTT_CLIENT_CERT=                          # Client certificate (for mTLS)
# MQTT_CLIENT_KEY=                           # Client private key (for mTLS)

# --- API Server / Admin Credentials ---
MOSORO_ADMIN_USERNAME=admin          # Username for the admin API user
MOSORO_ADMIN_PASSWORD=               # REQUIRED: Set a strong password for the admin API user

# --- JWT Authentication ---
MOSORO_JWT_SECRET=                   # REQUIRED: Random secret for signing JWT tokens (min 32 chars)
# MOSORO_JWT_EXPIRATION_MINUTES=60   # Optional: Token expiration time in minutes (default: 60)

# --- Rate Limiting ---
# MOSORO_RATE_LIMIT_REQUESTS=100     # Optional: Max requests per window (default: 100)
# MOSORO_RATE_LIMIT_WINDOW=60        # Optional: Rate limit window in seconds (default: 60)

# --- Gateway ---
RULES_PATH=/app/gateway/rules.yaml  # Path to the gateway rules YAML file
LOG_LEVEL=INFO                       # Logging level: DEBUG, INFO, WARNING, ERROR

# --- Agent Configuration ---
# CONFIG_PATH=/app/agents/config/example.yaml  # Path to agent YAML config file

# --- Frontend ---
VITE_API_URL=http://localhost:8000   # API URL used by the frontend dashboard
