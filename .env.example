# =============================================================================
# Mosoro Core — Environment Variables
# =============================================================================
# Most users: just run `make demo` — no .env needed!
#
# For production or custom setups, copy this file to .env:
#   cp .env.example .env
# =============================================================================

# --- Robot Connections ---
# Auto-filled by `make setup` wizard. No manual editing needed for demo mode.
# See robots.yaml.example for robot fleet configuration.
# ROBOTS_CONFIG=robots.yaml

# --- MQTT Broker ---
MQTT_BROKER_HOST=mosquitto               # MQTT broker hostname
MQTT_BROKER_PORT=1883                     # 1883 = plain (dev), 8883 = TLS (prod)
MQTT_USE_TLS=false                        # Enable TLS for MQTT connections
# MQTT_USERNAME=                          # Optional: MQTT username (if not using mTLS)
# MQTT_PASSWORD=                          # Optional: MQTT password (if not using mTLS)
# MQTT_CA_CERT=/run/secrets/mqtt_ca_cert  # CA certificate (prod only)
# MQTT_CLIENT_CERT=                       # Client certificate for mTLS (prod only)
# MQTT_CLIENT_KEY=                        # Client private key for mTLS (prod only)

# --- Auth ---
MOSORO_ADMIN_USERNAME=admin               # Admin API username
MOSORO_ADMIN_PASSWORD=changeme-dev        # Admin password (change for production!)
MOSORO_JWT_SECRET=dev-secret-change-in-production-min-32-chars  # JWT signing secret (min 32 chars)
# MOSORO_JWT_EXPIRATION_MINUTES=60        # Token expiration in minutes (default: 60)

# --- Logging ---
LOG_LEVEL=INFO                            # DEBUG, INFO, WARNING, ERROR

# --- Gateway ---
RULES_PATH=/app/gateway/rules.yaml       # Path to gateway rules YAML

# --- Frontend ---
VITE_API_URL=http://localhost:8000        # API URL used by the dashboard

# --- Notifications (Optional) ---
# Set NOTIFY_WEBHOOK_URL to receive robot alerts via HTTP POST (e.g., Slack, PagerDuty, email)
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# NOTIFY_EVENTS=offline,error,task_failed  # Which events trigger the webhook (default: all three)
# ROBOT_OFFLINE_THRESHOLD=30              # Seconds without heartbeat before robot is marked offline
