# Mosoro Edge Agent Configuration (Single-Robot / Legacy Mode)
# =============================================================
#
# This file is used as the default config.yaml when no robots.yaml is found
# and no CONFIG_PATH environment variable is set.
#
# For multi-robot setups, prefer robots.yaml instead.
# See: mosoro-core/robots.yaml.example
#
# Tip: Use `make setup` in mosoro-core to configure this automatically.

# --- Robot Identity ---
robot_id: "locus-001"
vendor: "locus"

# --- Vendor-Specific Connection Details ---
# Adjust these for your robot vendor (locus, mir, fetch, geekplus, stretch, etc.)
api_base_url: "http://localhost:8080/api"
api_key: "your-api-key-here"

# --- MQTT Broker Settings ---
# These can be overridden by environment variables:
#   MQTT_BROKER_HOST, MQTT_BROKER_PORT, MQTT_USE_TLS
mqtt_broker: "localhost"
mqtt_port: 1883
mqtt_use_tls: false

# TLS / mTLS certificates (uncomment for production)
# mqtt_ca_cert: "/run/secrets/mqtt_ca_cert"
# mqtt_client_cert: "/certs/locus-001.crt"
# mqtt_client_key: "/certs/locus-001.key"

# --- Polling & Operational Settings ---
poll_interval: 5.0
log_level: "DEBUG"
api_timeout: 10.0
max_retries: 3
